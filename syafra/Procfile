# SYAFRA Production Deployment
# ================================

# Run migrations on deployment
release: python manage.py migrate --noinput

# Start Gunicorn web server
web: gunicorn syafra.wsgi:application --workers 2 --threads 4 --timeout 120

# Optional: Run Celery worker for async tasks (uncomment if needed)
# worker: celery -A syafra worker --loglevel=info
