# Keep repository line endings consistent across OSes (best for Linux deploy targets like Render)
* text=auto eol=lf

# Windows-native script files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets (no EOL normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
