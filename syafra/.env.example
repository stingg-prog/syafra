# Django Settings (required in production: unique SECRET_KEY when DEBUG=False)
SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=False

# Optional: write logs.log / email_errors.log under BASE_DIR (default: on when DEBUG=True, off when False)
# LOG_TO_FILE=true
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
# For PostgreSQL:
DB_ENGINE=django.db.backends.postgresql
DB_NAME=syafra
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# For MySQL (uncomment if using):
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=syafra
# DB_USER=root
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=3306

# For SQLite (default for development):
# DB_ENGINE=django.db.backends.sqlite3

# Security (HTTPS enforcement - default True in production)
# Set to False only in development mode without HTTPS
SECURE_SSL_REDIRECT=True

# Email Configuration (Gmail with App Password)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here

# WhatsApp — customer wa.me links (optional if set in Admin → WhatsApp Settings)
# WHATSAPP_ENQUIRY_NUMBER=919876543210

# Twilio WhatsApp (optional: copy into Admin, or set for sync_whatsapp_from_env on deploy)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886
# TWILIO_WHATSAPP_ACTIVE=false
#
# After deploy, Procfile "release" runs: migrate + sync_whatsapp_from_env
# Sandbox: join Twilio sandbox, add your phone, message "join <code>" to the Twilio number

# Celery + Redis (Async Task Queue for WhatsApp notifications)
# Local development (defaults)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=300
#
# Production: Provide Redis URL from your PaaS provider
# - Heroku: Use heroku-redis add-on, auto-set REDIS_URL, then:
#   CELERY_BROKER_URL=$REDIS_URL/0
#   CELERY_RESULT_BACKEND=$REDIS_URL/1
#
# - Railway / Render: Create Redis service, copy connection string:
#   CELERY_BROKER_URL=redis://user:password@host:6379/0
#   CELERY_RESULT_BACKEND=redis://user:password@host:6379/1
#
# Optional: Celery task logging and alerts
# FLOWER_PORT=5555
# FLOWER_BASIC_AUTH=user:password
