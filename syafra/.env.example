# ============================================================
# SYAFRA — production / Render environment template
# ============================================================
# Copy to .env locally. Never commit .env.
#
# Before clicking Deploy (Render dashboard), confirm:
#   [ ] PostgreSQL linked
#   [ ] DATABASE_URL set (from linked DB)
#   [ ] DATABASE_SSL_REQUIRE=true on Render (or omit — default is true when DEBUG=False)
#   [ ] Pre-deploy: python manage.py migrate --noinput
#   [ ] After first deploy: logs show "Applying migrations..." OK
#   [ ] Build: pip install -r requirements.txt && python manage.py collectstatic --noinput
#   [ ] Start: gunicorn syafra.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --threads 4 --timeout 120
#   [ ] SECRET_KEY strong
#   [ ] ALLOWED_HOSTS correct
#   [ ] CSRF_TRUSTED_ORIGINS set (https://your exact host)
#   [ ] DOMAIN = public hostname (password reset / email links)
#   [ ] SendGrid (or Gmail) configured — do NOT use ALLOW_CONSOLE_EMAIL_IN_PRODUCTION in real production
#   [ ] Razorpay live keys

# --- Render: core Django (set these in the dashboard or Blueprint) ---
DEBUG=false
# Generate a value that satisfies deploy check (W009); paste once, never commit it:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=paste-output-from-command-above
DATABASE_URL=postgres://user:password@host:5432/dbname
# Render PostgreSQL requires SSL — use true or leave unset (defaults to true when DEBUG=False).
DATABASE_SSL_REQUIRE=true
ALLOWED_HOSTS=syafra.com,www.syafra.com,syafra.onrender.com
# Required for HTTPS: login, checkout, payments (CSRF). Must match your site URL(s).
# Same as: CSRF_TRUSTED_ORIGINS = ["https://your-app.onrender.com"]
CSRF_TRUSTED_ORIGINS=https://syafra.com,https://www.syafra.com,https://syafra.onrender.com

# Optional: add .onrender.com or extra domains (comma-separated, no spaces)
# ALLOWED_HOSTS=your-app.onrender.com,.onrender.com,www.example.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://www.example.com

# Links in emails (password reset); defaults to on when DEBUG=False
USE_HTTPS=True

# --- Database notes ---
# Production (DEBUG=False): DATABASE_URL required (link Postgres on Render).
# Local dev: DEBUG=True and omit DATABASE_URL → SQLite.
# Local Postgres without SSL: DEBUG=True and DATABASE_SSL_REQUIRE=false (never use false on Render).
# Do not set RENDER or RENDER_EXTERNAL_URL locally unless you mean to mimic Render; they are not used to pick the DB.
# SYAFRA_LOG_DB_CONFIG=true — log which DB backend settings chose (safe summary, no secrets).

# --- Payments ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=mysecret123

# --- Email (SendGrid API) — required for production launch ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER_EMAIL=your-verified-sender@yourdomain.com
DEFAULT_FROM_EMAIL=SYAFRA <your-verified-sender@yourdomain.com>
ORDER_ALERT_EMAILS=orders@syafra.com,owner@syafra.com
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=your-sendgrid-event-webhook-public-key
SENDGRID_EVENT_WEBHOOK_REQUIRE_SIGNATURE=true
SENDGRID_EVENT_WEBHOOK_MAX_AGE_SECONDS=300
EMAIL_SIMPLE_RETRY_ATTEMPTS=2
EMAIL_SIMPLE_RETRY_BASE_DELAY_SECONDS=1

# Public hostname only, no https:// — password reset, auth emails, link building (match your live URL).
DOMAIN=syafra.com

# --- HTTPS / headers ---
SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# --- Static media ---
# Cloudinary media storage (recommended for uploaded files)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Prefer CDN, nginx, or object storage. Enable only if you accept Django serving uploads:
# SERVE_MEDIA_VIA_DJANGO=false

# --- Cache (optional; multi-worker friendly) ---
# REDIS_URL=redis://:password@host:6379/0
# CACHE_TIMEOUT=300

# --- Logging (PaaS: usually console only) ---
LOG_TO_FILE=False

# --- One-time admin password reset during deploy (remove after successful deploy) ---
# ADMIN_PASSWORD_RESET_USERNAME=admin
# ADMIN_PASSWORD_RESET_PASSWORD=your-new-admin-password

# --- Staging ONLY (remove / do not set on real production) ---
# ALLOW_CONSOLE_EMAIL_IN_PRODUCTION=true

# --- Email Debug (verify configuration) ---
# Set to true temporarily, then check Render logs
SYAFRA_LOG_EMAIL_CONFIG=true
EMAIL_FAIL_SILENTLY=false

# --- WhatsApp ---
WHATSAPP_NUMBER=919037626684
WHATSAPP_DEFAULT_MESSAGE=Hi, I am interested in your products. Please share more details.

# --- Celery (if used) ---
# CELERY_BROKER_URL=redis://...
# CELERY_RESULT_BACKEND=redis://...
