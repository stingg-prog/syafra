# ============================================================
# SYAFRA - RENDER DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================
# REQUIRED FOR PRODUCTION
# ============================================================

# Django Security - IMPORTANT: Generate a strong secret key
# Generate at: https://djecrety.irqdunnuch/
SECRET_KEY=your-production-secret-key-generate-at-djecrety.irqdunnuch

# Set to False for production (RENDER WILL DO THIS)
DEBUG=False

# Add your Render domain and any custom domains
ALLOWED_HOSTS=.onrender.com,your-custom-domain.com

# ============================================================
# DATABASE (PostgreSQL from Render)
# ============================================================

# Copy from Render PostgreSQL connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://username:password@host:5432/database

# ============================================================
# RAZORPAY PAYMENT GATEWAY
# ============================================================
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use LIVE keys for production (rzp_live_xxx)

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# SENDGRID EMAIL SERVICE
# ============================================================
# Get API key from: https://app.sendgrid.com/settings/api_keys
# Sender email must be verified in SendGrid

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER_EMAIL=your-verified-sender@yourdomain.com
SENDGRID_SENDER_NAME=SYAFRA
DEFAULT_FROM_EMAIL=SYAFRA <your-verified-sender@yourdomain.com>

# Email service type
EMAIL_SERVICE=sendgrid

# ============================================================
# DOMAIN CONFIGURATION
# ============================================================

# Your Render application URL (without https://)
DOMAIN=syafra.onrender.com

# Protocol for URLs (https for production)
USE_HTTPS=True

# ============================================================
# SECURITY SETTINGS
# ============================================================

# HTTPS redirect (True for production)
SECURE_SSL_REDIRECT=True

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=https://.onrender.com,https://your-custom-domain.com

# ============================================================
# WHATSAPP CONFIGURATION
# ============================================================

WHATSAPP_NUMBER=919037626684
WHATSAPP_DEFAULT_MESSAGE=Hi, I am interested in your products. Please share more details.

# ============================================================
# LOGGING
# ============================================================

LOG_TO_FILE=False
